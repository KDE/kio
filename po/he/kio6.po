#, kde-format
msgid "Internal Error in Server"
msgstr "ОЕОњОЎОљОћ ОцОаОЎОъОЎОф ОЉОЕОеОф"

#: core/job_error.cpp:1082
#, kde-format
msgid ""
"The program on the server which provides access to the <strong>%1</strong> "
"protocol has reported an internal error: %2."
msgstr ""
"ОћОфОЋОЏОаОЎОф ОЉОЕОеОф ОЕОъОАОцОДОф ОњОЎОЕОћ ОюОцОеОЋОўОЋОДОЋОю <strong>%1</strong> ОЊОЎОЋОЋОЌОћ ОбОю ОЕОњОЎОљОћ "
"ОцОаОЎОъОЎОф: %2."

