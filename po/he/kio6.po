#: core/copyjob.cpp:167 kioworkers/file/file_unix.cpp:998
#, kde-format
msgctxt ""
"The first arg is the path to the symlink that couldn't be created, the "
"secondarg is the filesystem type (e.g. vfat, exfat)"
msgid ""
"Could not create symlink \"%1\".\n"
"The destination filesystem (%2) doesn't support symlinks."
msgstr ""
"ОљОЎ ОљОцОЕОе ОюОЎОдОЋОе ОљОф ОћОДОЎОЕОЋОе ОћОАОъОюОЎ Рђъ%1РђЮ.\n"
"ОъОбОеОЏОф ОћОДОЉОдОЎОЮ ОЉОЎОбОЊ (%2) ОюОљ ОфОЋОъОЏОф ОЉОДОЎОЕОЋОеОЎОЮ ОАОъОюОЎОЎОЮ."

#: core/copyjob.cpp:179
#, kde-format
msgid ""
"Could not create \"%1\".\n"
"The destination filesystem (%2) disallows the following characters in folder "
"names: %3\n"
"Selecting Replace will replace any invalid characters (in the destination "
"folder name) with an underscore \"_\"."
msgstr ""
"ОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОљОф Рђъ%1РђЮ.\n"
"ОъОбОеОЏОф ОћОДОЉОдОЎОЮ ОЕОЉОЎОбОЊ (%2) ОюОљ ОъОеОЕОћ ОюОћОЕОфОъОЕ ОЉОфОЋОЋОЎОЮ ОћОЉОљОЎОЮ ОЉОЕОъОЋОф ОфОЎОДОЎОЋОф: %3\n"
"ОЉОЌОЎОеОћ ОЉОћОЌОюОцОћ ОфОЌОюОЎОБ ОљОф ОћОфОЋОЋОЎОЮ ОћОЕОњОЋОЎОЎОЮ (ОЉОЕОъОЋОф ОфОЎОДОЎОЋОф ОћОЎОбОЊ) ОЉОДОЋ ОфОЌОфОЎ Рђъ_РђЮ."

#: core/copyjob.cpp:187
#, kde-format
msgid ""
"Could not create \"%1\".\n"
"The destination filesystem (%2) disallows the following characters in file "
