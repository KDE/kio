"thê-sing khuân-hān.\n"
"Tshiánn tī kái-piàn khuân-hān liáu-āu koh tîng-tshì."

#: core/job_error.cpp:261
#, kde-format
msgid "File is too large to be trashed."
msgstr "Tóng-àn siōng tuā, bô-huat-tōo suá-khì pùn-sò-tháng."

#: core/job_error.cpp:264
#, kde-format
msgid "A trash folder could not be found or created for this location."
msgstr ""
"Bô-huat-tōo tshuē-tio̍h á-sī kiàn-li̍p tsit-ê uī-tì ê pùn-sò-tháng tsu-liāu-"
"giap-á."

#: core/job_error.cpp:267
#, kde-format
msgid ""
"Unknown error code %1\n"
"%2\n"
"Please send a full bug report at https://bugs.kde.org."
msgstr ""
"M̄-tsai ê tshò-gōo tāi-bé %1\n"
"%2\n"
"Tshiánn thuân uân-tsíng--ê bug report hōo https://bugs.kde.org."

